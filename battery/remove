#!/bin/bash

# Release the I2C device before unloading the module so the driver's devm
# cleanup runs against a live device.  Skip if the device is not present
# (e.g. it was never instantiated, or was already removed).
if [ -e /sys/bus/i2c/devices/1-0064 ]; then
    echo "Releasing I2C device 1-0064..."
    echo 0x64 | sudo tee /sys/bus/i2c/devices/i2c-1/delete_device
else
    echo "Device 1-0064 not present; skipping delete_device."
fi

sudo dkms remove -m oneUpPower -v 1.0 2>/dev/null || true
sudo rmmod oneUpPower
sudo rm -vf /lib/modules/`uname -r`/kernel/drivers/power/supply/oneUpPower.ko
sudo sh -c "sed -i '/oneUpPower/d' /etc/modules"
sudo rm -vf /etc/modprobe.d/oneUpPower.conf
sudo depmod -a

# Note: this script does not touch the DT overlay.  If the overlay was
# installed separately, remove it manually:
#
#   sudo rm /boot/firmware/overlays/argon-oneup-battery.dtbo
#   # remove the dtoverlay=argon-oneup-battery line from /boot/firmware/config.txt
#   sudo reboot

sync
